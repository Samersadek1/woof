# Copy to `.env` and fill in (restart `npm run dev` after changes).
# Supabase: Project Settings → API → Project URL and anon / publishable key.

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=YOUR_PUBLISHABLE_OR_ANON_KEY

# Claude API key is now a Supabase secret — set it with:
# supabase secrets set ANTHROPIC_API_KEY=your_key_here

# Server-only vars (Vercel / API routes). NEVER expose service role in frontend.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=YOUR_PUBLISHABLE_OR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Public app URL used by staff invite emails (no trailing slash).
# Set this on Vercel (Production + Preview) to your deployed origin.
# Also set Supabase Auth → URL Configuration → Site URL to the same value.
APP_BASE_URL=https://woof-neon.vercel.app

# WhatsApp bridge API route (/api/whatsapp/incoming)
# Shared secret required in x-bridge-secret header.
WHATSAPP_BRIDGE_SECRET=replace-with-strong-shared-secret
# Optional downstream processor URL. If unset, endpoint only validates/acknowledges.
WHATSAPP_BRIDGE_TARGET_URL=
# Optional secret forwarded to downstream as x-bridge-secret.
WHATSAPP_BRIDGE_TARGET_SECRET=
