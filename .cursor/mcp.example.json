{
  "mcpServers": {
    "supabase": {
      "command": "npx",
      "args": [
        "-y",
        "@supabase/mcp-server-supabase@latest",
        "--project-ref=wineliuwejkxwsdbrthb",
        "--read-only",
        "--features=database,docs"
      ],
      "env": {
        "SUPABASE_ACCESS_TOKEN": "past_your_token_here"
      }
    },
    "stitch": {
      "command": "node",
      "args": ["${workspaceFolder}/scripts/stitch-mcp-proxy.mjs"],
      "env": {
        "STITCH_API_KEY": "${env:STITCH_API_KEY}"
      }
    }
  }
}
