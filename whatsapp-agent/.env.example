ANTHROPIC_API_KEY=
SUPABASE_URL=https://wineliuwejkxwsdbrthb.supabase.co
SUPABASE_SERVICE_KEY=
# Optional alias if you use service role naming in Railway:
# SUPABASE_SERVICE_ROLE_KEY=

# Tenant for this Railway service. Must match public.tenants.slug.
TENANT_SLUG=woof

# Optional overrides; otherwise tenant row + defaults are used.
STAFF_GROUP_ID=
# WA_SESSION_CLIENT_ID=woof-whatsapp-main
# Optional if you provide a system Chrome binary path:
# CHROME_EXECUTABLE_PATH=/usr/bin/chromium
# Session bucket used by RemoteAuth:
# WHATSAPP_SESSION_BUCKET=whatsapp-sessions

# History bounds:
# AGENT_HISTORY_KEEP_TURNS=16
# AGENT_HISTORY_SUMMARY_TRIGGER=24

# Railway log watcher options:
# RAILWAY_SERVICE=woof-whatsapp-agent
# RAILWAY_ENVIRONMENT=production
# RAILWAY_LOG_LINES=600
# RAILWAY_POLL_INTERVAL_MS=45000
# RAILWAY_LOG_STATE_FILE=.railway-log-state.json
# Optional full command override:
# RAILWAY_LOG_COMMAND=railway logs --service "woof-whatsapp-agent" --environment "production" --lines 600
# Set 1 for JSON output:
# RAILWAY_WATCH_JSON=0

# STAFF_GROUP_ID: run the service once, scan the QR code,
# then check the terminal -- all group IDs are printed on ready.
# Copy the ID of your staff WhatsApp group.

# company-chat bridge (Mastra agents on WHATSAPP_EXTERNAL)
# COMPANY_CHAT_URL=https://your-company-chat.vercel.app
# WHATSAPP_BRIDGE_SECRET=same value as company-chat WHATSAPP_BRIDGE_SECRET
# WHATSAPP_BRIDGE_TARGET_SECRET=secret for POST /bridge/outgoing from company-chat
# WHATSAPP_BRAND_PHONE=+971558992235
# Optional if client.info is not ready yet; otherwise derived from linked device.
