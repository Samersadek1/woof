# Session bucket used by RemoteAuth:
# WHATSAPP_SESSION_BUCKET=whatsapp-sessions
# Railway log watcher options:
# RAILWAY_SERVICE=msh-whatsapp-agent
# RAILWAY_ENVIRONMENT=production
# RAILWAY_LOG_LINES=600
# RAILWAY_POLL_INTERVAL_MS=45000
# RAILWAY_LOG_STATE_FILE=.railway-log-state.json
# Optional full command override:
# RAILWAY_LOG_COMMAND=railway logs --service "msh-whatsapp-agent" --environment "production" --lines 600
# Set 1 for JSON output:
# RAILWAY_WATCH_JSON=0

